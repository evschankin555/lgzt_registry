# Telegram bot
telegram_bot_api=<PASTE_TELEGRAM_BOT_TOKEN_HERE>

# Runtime DB URL for the bot and shared app logic
# Local default:
DATABASE_URL=sqlite+aiosqlite:///app.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://bot_user:bot_pass@127.0.0.1:5432/lgzt_registry

# Optional sync URL for Alembic.
# If omitted, Alembic derives it from DATABASE_URL where possible.
# Example:
# ALEMBIC_DATABASE_URL=postgresql+psycopg://bot_user:bot_pass@127.0.0.1:5432/lgzt_registry

# Registry dashboard auth / JWT
REGISTRY_ADMIN_PASSWORD=admin2026
REGISTRY_SECRET_KEY=<PASTE_RANDOM_SECRET_HERE>

# MAX bot
MAX_BOT_TOKEN=<PASTE_MAX_BOT_TOKEN_HERE>
MAX_WEBHOOK_SECRET=<PASTE_MAX_WEBHOOK_SECRET_HERE>
MAX_WEBHOOK_URL=https://your-domain.example/max-bot/webhook
# Optional if the default MAX API base URL ever needs override
# MAX_API_BASE_URL=https://...
# Enable raw payload logging during the technical spike
MAX_DEBUG_LOG_PAYLOADS=true
